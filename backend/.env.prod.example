# =============================================================
# MathModelAgent 生产环境配置模板
# =============================================================
# 使用方式:
#   1. 复制本文件为 .env.prod: cp .env.prod.example .env.prod
#   2. 填写所有标记为 <必须设置> 的配置项
#   3. 通过 docker-compose.prod.yml 启动服务
# =============================================================

# ============= 基础配置 =============
ENV=production
DEBUG=false
LOG_LEVEL=WARNING

# ============= 安全配置（必须设置） =============
# API Key 加密主密钥（用于 AES-256-GCM 加密用户 API Key）
# <必须设置> 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY_MASTER_SECRET=

# ============= 协调者 Agent 配置 =============
# <必须设置> 填写你的 LLM API Key 和模型名称
COORDINATOR_API_KEY=your_coordinator_api_key
COORDINATOR_MODEL=deepseek/deepseek-chat
COORDINATOR_BASE_URL=https://api.deepseek.com

# ============= 建模者 Agent 配置 =============
MODELER_API_KEY=your_modeler_api_key
MODELER_MODEL=deepseek/deepseek-chat
MODELER_BASE_URL=https://api.deepseek.com

# ============= 代码者 Agent 配置 =============
CODER_API_KEY=your_coder_api_key
CODER_MODEL=deepseek/deepseek-chat
CODER_BASE_URL=https://api.deepseek.com

# ============= 写作者 Agent 配置 =============
WRITER_API_KEY=your_writer_api_key
WRITER_MODEL=deepseek/deepseek-chat
WRITER_BASE_URL=https://api.deepseek.com

# ============= Agent 运行参数 =============
MAX_CHAT_TURNS=70
MAX_RETRIES=5

# ============= Redis 配置 =============
# Docker 内部通信使用服务名 "redis"
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# ============= 服务器配置 =============
# <必须设置> 替换为你的实际域名
SERVER_HOST=https://your-domain.com

# ============= CORS 跨域配置 =============
# <必须设置> 替换为你的实际前端域名，多个用逗号分隔
CORS_ALLOW_ORIGINS=https://your-domain.com

# ============= 代码执行环境（可选） =============
# E2B 云端代码执行器 API Key（留空则使用本地 Jupyter）
E2B_API_KEY=

# ============= 学术搜索（可选） =============
# OpenAlex 学术搜索 API 邮箱
OPENALEX_EMAIL=
