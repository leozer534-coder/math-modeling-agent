ENV=dev
# support all model, check out https://docs.litellm.ai/docs/providers
# e.g. gpt-4.1,deepseek/deepseek-chat
# docs/md/tutorial
# 为每个 agent 配置合适的模型
COORDINATOR_API_KEY=sk-8f1b66c7fb344c3e8aa8e4da8cf16c73
COORDINATOR_MODEL=openai/claude-opus-4-6-thinking
COORDINATOR_BASE_URL=http://127.0.0.1:8045/v1

# 推荐 thinking model
MODELER_API_KEY=sk-8f1b66c7fb344c3e8aa8e4da8cf16c73
MODELER_MODEL=openai/claude-opus-4-6-thinking
MODELER_BASE_URL=http://127.0.0.1:8045/v1

CODER_API_KEY=sk-8f1b66c7fb344c3e8aa8e4da8cf16c73
CODER_MODEL=openai/claude-opus-4-6-thinking
CODER_BASE_URL=http://127.0.0.1:8045/v1

WRITER_API_KEY=sk-8f1b66c7fb344c3e8aa8e4da8cf16c73
WRITER_MODEL=openai/claude-opus-4-6-thinking
WRITER_BASE_URL=http://127.0.0.1:8045/v1

# 模型最大问答次数
MAX_CHAT_TURNS=70
# 思考反思次数
MAX_RETRIES=5

# 不需要填，默认调用本地 Python
# E2B_API_KEY=
SERVER_HOST=http://localhost:8001
# 使用 email 注册账号从 https://openalex.org/ 文献
OPENALEX_EMAIL=

LOG_LEVEL=DEBUG
DEBUG=true
# 确保安装 Redis
# 如果是docker: REDIS_URL=redis://redis:6379/0
# 本地部署 : redis://localhost:6379/0
# REDIS_URL=redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
DATABASE_URL=sqlite+aiosqlite:///./mathmodel_v2.db