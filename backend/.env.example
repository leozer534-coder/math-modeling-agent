# 环境配置
ENV=dev

# ===== 协调者 Agent 配置 =====
COORDINATOR_API_KEY=your_api_key_here
COORDINATOR_MODEL=deepseek/deepseek-chat
COORDINATOR_BASE_URL=https://api.deepseek.com

# ===== 建模者 Agent 配置 =====
MODELER_API_KEY=your_api_key_here
MODELER_MODEL=deepseek/deepseek-chat
MODELER_BASE_URL=https://api.deepseek.com

# ===== 代码者 Agent 配置 =====
CODER_API_KEY=your_api_key_here
CODER_MODEL=deepseek/deepseek-chat
CODER_BASE_URL=https://api.deepseek.com

# ===== 写作者 Agent 配置 =====
WRITER_API_KEY=your_api_key_here
WRITER_MODEL=deepseek/deepseek-chat
WRITER_BASE_URL=https://api.deepseek.com

# ===== Agent 运行参数 =====
MAX_CHAT_TURNS=70
MAX_RETRIES=5

# ===== 代码执行环境 =====
# E2B 云端代码执行器 API Key (可选，留空则使用本地 Jupyter)
E2B_API_KEY=

# ===== 服务器配置 =====
SERVER_HOST=http://localhost:8000

# ===== 学术搜索 =====
# OpenAlex 学术搜索 API 邮箱 (可选)
OPENALEX_EMAIL=

# ===== 日志配置 =====
LOG_LEVEL=DEBUG
DEBUG=true

# ===== Redis 配置 =====
# 本地开发: redis://localhost:6379/0
# Docker 环境: redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

# ===== 安全配置 =====
# API Key 加密主密钥（用于 AES-256-GCM 加密用户 API Key）
# 生产环境必须设置！建议至少 32 个字符的随机字符串
# 可通过 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成
# 开发环境不设置时使用内置回退密钥（不安全，仅供本地调试）
API_KEY_MASTER_SECRET=

# ===== CORS 跨域配置 =====
# 允许的前端域名，多个用逗号分隔
# 开发环境示例: http://localhost:5173,http://localhost:3000
# 生产环境示例: https://your-domain.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
