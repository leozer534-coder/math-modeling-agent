# 本地开发配置示例
# 复制此文件为 .env.dev 并填入您的真实 API Key

ENV=dev

# ===== 请在此处填入您的真实 API Key =====
COORDINATOR_API_KEY=sk-your-actual-api-key
COORDINATOR_MODEL=deepseek/deepseek-chat
COORDINATOR_BASE_URL=https://api.deepseek.com

MODELER_API_KEY=sk-your-actual-api-key
MODELER_MODEL=deepseek/deepseek-chat
MODELER_BASE_URL=https://api.deepseek.com

CODER_API_KEY=sk-your-actual-api-key
CODER_MODEL=deepseek/deepseek-chat
CODER_BASE_URL=https://api.deepseek.com

WRITER_API_KEY=sk-your-actual-api-key
WRITER_MODEL=deepseek/deepseek-chat
WRITER_BASE_URL=https://api.deepseek.com

MAX_CHAT_TURNS=70
MAX_RETRIES=5
E2B_API_KEY=

SERVER_HOST=http://localhost:8000
OPENALEX_EMAIL=

LOG_LEVEL=DEBUG
DEBUG=true

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20

CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
