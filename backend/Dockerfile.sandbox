# 数学建模沙箱执行环境
# MathModel Sandbox Docker Image
#
# 构建: docker build -t mathmodel-sandbox:latest -f Dockerfile.sandbox .
# 使用: docker run --rm -v $(pwd):/workspace mathmodel-sandbox:latest python main.py
#
# 运行时必须添加安全参数:
#   docker run --rm \
#     --network=none \
#     --read-only \
#     --cap-drop=ALL \
#     --security-opt no-new-privileges \
#     --memory=512m \
#     --cpus=0.5 \
#     --tmpfs /tmp:size=100m \
#     -v $(pwd):/workspace:ro \
#     mathmodel-sandbox:latest python main.py

# 锁定到具体修订版本，确保构建可复现且避免上游镜像引入未审计的变更
FROM python:3.11.11-slim-bookworm

# 设置标签
LABEL maintainer="MathModelAgent Team"
LABEL description="Secure sandbox for executing mathematical modeling code"
LABEL version="1.0"

# 创建非root用户
RUN groupadd -r sandbox && useradd -r -g sandbox sandbox

# 安装中文字体包（支持 matplotlib 中文渲染）
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        fonts-wqy-microhei \
        fonts-noto-cjk \
    && fc-cache -fv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 设置工作目录
WORKDIR /workspace

# 安装科学计算常用库
RUN pip install --no-cache-dir \
    # 基础科学计算
    numpy>=1.24.0 \
    scipy>=1.11.0 \
    pandas>=2.0.0 \
    # 数据可视化
    matplotlib>=3.7.0 \
    seaborn>=0.12.0 \
    plotly>=5.15.0 \
    # 机器学习
    scikit-learn>=1.3.0 \
    xgboost>=1.7.0 \
    lightgbm>=4.0.0 \
    # 优化求解
    cvxpy>=1.4.0 \
    pulp>=2.7.0 \
    pymoo>=0.6.0 \
    # 统计分析
    statsmodels>=0.14.0 \
    # 符号计算
    sympy>=1.12 \
    # 网络分析
    networkx>=3.1 \
    # 数据处理
    openpyxl>=3.1.0 \
    xlrd>=2.0.0 \
    # Jupyter支持
    nbformat>=5.9.0 \
    nbconvert>=7.8.0 \
    && rm -rf /root/.cache/pip

# 创建临时目录
RUN mkdir -p /tmp/sandbox && chmod 755 /tmp/sandbox

# 设置环境变量
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    MPLBACKEND=Agg

# 安全配置
# 禁止访问敏感路径
RUN chmod 000 /etc/shadow /etc/passwd- /etc/shadow- 2>/dev/null || true

# 切换到非root用户
USER sandbox

# 健康检查
HEALTHCHECK --interval=30s --timeout=3s \
    CMD python -c "import numpy; print('OK')" || exit 1

# 默认命令
CMD ["python", "--version"]
